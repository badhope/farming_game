# ==========================================
# 农场大亨 - 环境变量配置示例
# ==========================================
# 复制此文件为 .env 并填入实际值

# ==========================================
# 数据库配置
# ==========================================
DATABASE_URL=postgresql://farming_game:farming_game_pass_2024@postgres:5432/farming_game
REDIS_URL=redis://redis:6379/0

# ==========================================
# JWT 认证配置
# ==========================================
JWT_SECRET=changeme_secret_key_2024_generate_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# 服务器配置
# ==========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
MAX_CONNECTIONS=50

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/farming_game/app.log

# ==========================================
# CORS 配置
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==========================================
# 游戏配置
# ==========================================
GAME_VERSION=1.0.0
AUTO_SAVE_INTERVAL=300
MAX_CLOUD_SAVES=10
